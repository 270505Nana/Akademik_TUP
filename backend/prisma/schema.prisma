// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  LECTURER
  ACADEMIC_STAFF
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  noTelp    String?   @map("no_telp")
  role      Role?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  academicStaff AcademicStaff?
  lecturer      Lecturer?
  student       Student?

  @@map("user")
}

// Master Data Tim Akademik
model AcademicStaff {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  skResponse SkResponse[]

  @@map("academic_staff")
}

// Master Data Dosen
model ResearchGroup {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  lecturer Lecturer[]

  @@map("research_group")
}

model Lecturer {
  id           Int       @id @default(autoincrement())
  nip          String    @unique
  nidn         String    @unique
  lecturerCode String    @map("lecturer_code")
  name         String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  researchGroupId Int           @map("research_group_id")
  researchGroup   ResearchGroup @relation(fields: [researchGroupId], references: [id])

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  student                         Student[]
  skSubmissionsSupervisor1        SkSubmission[]         @relation("SkSubmissionSupervisor1")
  skSubmissionsSupervisor2        SkSubmission[]         @relation("SkSubmissionSupervisor2")
  skFilesSupervisor1              SkFile[]               @relation("SkFileSupervisor1")
  skFilesSupervisor2              SkFile[]               @relation("SkFileSupervisor2")
  sidangRegistrationSupervisor1   SidangRegistration[]   @relation("SidangRegistrationSupervisor1")
  sidangRegistrationSupervisor2   SidangRegistration[]   @relation("SidangRegistrationSupervisor2")
  yudisiumRegistrationSupervisor1 YudisiumRegistration[] @relation("YudisiumRegistrationSupervisor1")
  yudisiumRegistrationSupervisor2 YudisiumRegistration[] @relation("YudisiumRegistrationSupervisor2")

  @@map("lecturer")
}

// Master Data Mahasiswa
model Faculty {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  studyProgram StudyProgram[]

  @@map("faculty")
}

model StudyProgram {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  facultyId Int     @map("faculty_id")
  faculty   Faculty @relation(fields: [facultyId], references: [id])

  student Student[]

  @@map("study_program")
}

model Student {
  id        Int       @id @default(autoincrement())
  nim       String    @unique
  name      String
  className String    @map("class_name")
  sks       Int
  ipk       Int
  tak       Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  studyProgramId Int          @map("study_program_id")
  studyProgram   StudyProgram @relation(fields: [studyProgramId], references: [id])

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  academicAdvisorId Int      @map("lecturer_id") // Dosen Wali
  academicAdvisor   Lecturer @relation(fields: [academicAdvisorId], references: [id])

  skSubmission         SkSubmission[]
  skFile               SkFile[]
  sidangRegistration   SidangRegistration[]
  yudisiumRegistration YudisiumRegistration[]

  @@map("student")
}

// Surat Keputusan
model SkFile {
  id              Int       @id @default(autoincrement())
  fileUrl         String    @map("file_url")
  exp_date        DateTime  @db.Date
  proposalTitleId String    @map("proposal_title_id")
  proposalTitleEn String    @map("proposal_title_en")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  supervisor1Id Int      @map("supervisor_1_id")
  supervisor1   Lecturer @relation("SkFileSupervisor1", fields: [supervisor1Id], references: [id]) // Dosen Pembimbing 1

  supervisor2Id Int      @map("supervisor_2_id")
  supervisor2   Lecturer @relation("SkFileSupervisor2", fields: [supervisor2Id], references: [id]) // Dosen Pembimbing 2

  @@map("sk_file")
}

model SkSubmission {
  id              Int       @id @default(autoincrement())
  proposalTitleId String    @map("proposal_title_id")
  proposalTitleEn String    @map("proposal_title_en")
  attachmentUrl   String    @map("attachment_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  supervisor1Id Int      @map("supervisor_1_id")
  supervisor1   Lecturer @relation("SkSubmissionSupervisor1", fields: [supervisor1Id], references: [id]) // Dosen Pembimbing 1

  supervisor2Id Int      @map("supervisor_2_id")
  supervisor2   Lecturer @relation("SkSubmissionSupervisor2", fields: [supervisor2Id], references: [id]) // Dosen Pembimbing 2

  skResponse SkResponse[]

  @@map("sk_submission")
}

model SkResponse {
  id                       Int       @id @default(autoincrement())
  hasUploadedFinalProposal Boolean   @map("has_uploaded_final_proposal")
  hasTakenLanguageTest     Boolean   @map("has_taken_language_test")
  message                  String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  academicStaffId Int
  academicStaff   AcademicStaff @relation(fields: [academicStaffId], references: [id])

  skSubmissionId Int
  skSubmission   SkSubmission @relation(fields: [skSubmissionId], references: [id])

  @@map("sk_response")
}

// Daftar Sidang
model SidangPeriod {
  id         Int       @id @default(autoincrement())
  name       String
  start_date DateTime  @db.Date
  end_date   DateTime  @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@map("sidang_period")
}

model SidangScheme {
  id        Int       @id @default(autoincrement())
  name      String
  field     Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sidangRegistration   SidangRegistration[]
  yudisiumRegistration YudisiumRegistration[]

  @@map("sidang_scheme")
}

model SidangRegistration {
  id            Int      @id @default(autoincrement())
  programType   String   @map("program_type")
  sks           Int
  ipk           Int
  tak           Int
  sk_exp_date   DateTime @db.Date
  thesisTitleId String   @map("thesis_title_id")
  thesisTitleEn String   @map("thesis_title_en")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime @map("deleted_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  supervisor1Id Int      @map("supervisor_1_id")
  supervisor1   Lecturer @relation("SidangRegistrationSupervisor1", fields: [supervisor1Id], references: [id]) // Dosen Pembimbing 1

  supervisor2Id Int      @map("supervisor_2_id")
  supervisor2   Lecturer @relation("SidangRegistrationSupervisor2", fields: [supervisor2Id], references: [id]) // Dosen Pembimbing 2

  sidangSchemeId Int          @map("sidang_scheme_id")
  sidangScheme   SidangScheme @relation(fields: [sidangSchemeId], references: [id])

  sidangSubmission   SidangSubmission[]
  cumlaudeSubmission CumlaudeSubmission[]

  @@map("sidang_registration")
}

model SidangSubmission {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime @map("deleted_at")

  sidangRegistrationId Int                @map("sidang_registration_id")
  sidangRegistration   SidangRegistration @relation(fields: [sidangRegistrationId], references: [id])

  @@map("sidang_submission")
}

// Daftar Yudisium

model CumlaudeScheme {
  id        Int       @id @default(autoincrement())
  name      String
  field     Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  yudisiumRegistration YudisiumRegistration[]

  @@map("cumlaude_scheme")
}

model YudisiumRegistration {
  id            Int      @id @default(autoincrement())
  programType   String   @map("program_type")
  ipk           Int
  tak           Int
  sk_exp_date   DateTime @db.Date
  thesisTitleId String   @map("thesis_title_id")
  thesisTitleEn String   @map("thesis_title_en")
  isConfirmed   Boolean  @map("is_confirmed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime @map("deleted_at")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  supervisor1Id Int      @map("supervisor_1_id")
  supervisor1   Lecturer @relation("YudisiumRegistrationSupervisor1", fields: [supervisor1Id], references: [id]) // Dosen Pembimbing 1

  supervisor2Id Int      @map("supervisor_2_id")
  supervisor2   Lecturer @relation("YudisiumRegistrationSupervisor2", fields: [supervisor2Id], references: [id]) // Dosen Pembimbing 2

  sidangSchemeId Int          @map("sidang_scheme_id")
  sidangScheme   SidangScheme @relation(fields: [sidangSchemeId], references: [id])

  cumlaudeSchemeId Int            @map("cumlaude_scheme_id")
  cumlaudeScheme   CumlaudeScheme @relation(fields: [cumlaudeSchemeId], references: [id])

  @@map("yudisium_registration")
}

model CumlaudeSubmission {
  id        Int      @id @default(autoincrement())
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime @map("deleted_at")

  yudisiumRegistrationId Int                @map("yudisium_registration_id")
  yudisiumRegistration   SidangRegistration @relation(fields: [yudisiumRegistrationId], references: [id])

  @@map("cumlaude_submission")
}
