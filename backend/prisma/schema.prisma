model TemplateUpload {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  name      String
  slug      String    @unique // contoh: formulirPenerbitanSkta
  filename  String
  path      String
  isPublish Boolean
}
