// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  LECTURER
  ACADEMIC_STAFF
}

model User {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  username      String         @unique
  email         String         @unique
  password      String
  phone         String?        @unique
  role          Role?
  academicStaff AcademicStaff?
  lecturer      Lecturer?
  student       Student?
}

// Master Data Tim Akademik
model AcademicStaff {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  name          String
  user          User           @relation(fields: [userId], references: [id])
  userId        Int            @unique
  sktaResponses SktaResponse[]
}

// Master Data Dosen
model ResearchGroup {
  id        Int        @id @default(autoincrement())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  name      String
  lecturers Lecturer[]
}

model Lecturer {
  id                               Int                    @id @default(autoincrement())
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  deletedAt                        DateTime?
  nip                              String                 @unique
  nidn                             String                 @unique
  lecturerCode                     String
  name                             String
  researchGroup                    ResearchGroup          @relation(fields: [researchGroupId], references: [id])
  researchGroupId                  Int
  user                             User                   @relation(fields: [userId], references: [id])
  userId                           Int                    @unique
  students                         Student[]
  pembimbing1SktaRequests          SktaRequest[]          @relation("Pembimbing1SktaRequests")
  pembimbing2SktaRequests          SktaRequest[]          @relation("Pembimbing2SktaRequests")
  pembimbing1SidangRegistrations   SidangRegistration[]   @relation("Pembimbing1SidangRegistrations")
  pembimbing2SidangRegistrations   SidangRegistration[]   @relation("Pembimbing2SidangRegistrations")
  pembimbing1YudisiumRegistrations YudisiumRegistration[] @relation("Pembimbing1YudisiumRegistrations")
  pembimbing2YudisiumRegistrations YudisiumRegistration[] @relation("Pembimbing2YudisiumRegistrations")
}

// Master Data Mahasiswa
model Faculty {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  name          String
  studyPrograms StudyProgram[]
}

model StudyProgram {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  name      String
  faculty   Faculty   @relation(fields: [facultyId], references: [id])
  facultyId Int
  students  Student[]
}

model Student {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  nim                   String                 @unique
  name                  String
  className             String
  sks                   Int?
  ipk                   Float?
  tak                   Int?
  studyProgram          StudyProgram           @relation(fields: [studyProgramId], references: [id])
  studyProgramId        Int
  user                  User                   @relation(fields: [userId], references: [id])
  userId                Int                    @unique
  dosenWali             Lecturer               @relation(fields: [dosenWaliId], references: [id])
  dosenWaliId           Int // Dosen Wali
  sktaRequests          SktaRequest[]
  sidangRegistrations   SidangRegistration[]
  yudisiumRegistrations YudisiumRegistration[]
}

// Surat Keputusan TA
model SktaRequest {
  id                 Int                 @id @default(autoincrement())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  proposalTitleId    String
  proposalTitleEn    String
  student            Student             @relation(fields: [studentId], references: [id])
  studentId          Int
  dosenPembimbing1   Lecturer            @relation("Pembimbing1SktaRequests", fields: [dosenPembimbing1Id], references: [id]) // Dosen Pembimbing 1
  dosenPembimbing1Id Int
  dosenPembimbing2   Lecturer            @relation("Pembimbing2SktaRequests", fields: [dosenPembimbing2Id], references: [id]) // Dosen Pembimbing 2
  dosenPembimbing2Id Int
  sktaRequestUploads SktaRequestUpload[]
  sktaResponses      SktaResponse[]
}

model SktaRequestUpload {
  id            Int         @id @default(autoincrement())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  name          String
  filename      String
  path          String
  sktaRequest   SktaRequest @relation(fields: [sktaRequestId], references: [id])
  sktaRequestId Int
}

model SktaResponse {
  id                       Int                  @id @default(autoincrement())
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deletedAt                DateTime?
  hasUploadedFinalProposal Boolean
  hasTakenLanguageTest     Boolean
  message                  String?
  expDate                  DateTime?            @db.Date
  academicStaff            AcademicStaff        @relation(fields: [academicStaffId], references: [id])
  academicStaffId          Int
  sktaRequest              SktaRequest          @relation(fields: [sktaRequestId], references: [id])
  sktaRequestId            Int
  sktaResponseUploads      SktaResponseUpload[]
}

model SktaResponseUpload {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  name           String
  filename       String
  path           String
  sktaResponse   SktaResponse @relation(fields: [sktaResponseId], references: [id])
  sktaResponseId Int
}

// Daftar Sidang
model SidangPeriod {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  name       String
  start_date DateTime  @db.Date
  end_date   DateTime  @db.Date
}

model SidangScheme {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  name                  String
  field                 Json?
  sidangRegistrations   SidangRegistration[]
  yudisiumRegistrations YudisiumRegistration[]
}

model SidangRegistration {
  id                 Int                @id @default(autoincrement())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime
  programType        String
  sks                Int
  ipk                Float
  tak                Int
  skta_exp_date      DateTime           @db.Date
  thesisTitleId      String
  thesisTitleEn      String
  student            Student            @relation(fields: [studentId], references: [id])
  studentId          Int
  dosenPembimbing1   Lecturer           @relation("Pembimbing1SidangRegistrations", fields: [dosenPembimbing1Id], references: [id]) // Dosen Pembimbing 1
  dosenPembimbing1Id Int
  dosenPembimbing2   Lecturer           @relation("Pembimbing2SidangRegistrations", fields: [dosenPembimbing2Id], references: [id]) // Dosen Pembimbing 2
  dosenPembimbing2Id Int
  sidangScheme       SidangScheme       @relation(fields: [sidangSchemeId], references: [id])
  sidangSchemeId     Int
  sidangSubmissions  SidangSubmission[]
}

model SidangSubmission {
  id                   Int                @id @default(autoincrement())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime
  data                 Json
  sidangRegistration   SidangRegistration @relation(fields: [sidangRegistrationId], references: [id])
  sidangRegistrationId Int
}

// Daftar Yudisium
model CumlaudeScheme {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  name                  String
  field                 Json?
  yudisiumRegistrations YudisiumRegistration[]
}

model YudisiumRegistration {
  id                  Int                  @id @default(autoincrement())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime
  programType         String
  ipk                 Float
  tak                 Int
  skta_exp_date       DateTime             @db.Date
  thesisTitleId       String
  thesisTitleEn       String
  isConfirmed         Boolean
  student             Student              @relation(fields: [studentId], references: [id])
  studentId           Int
  dosenPembimbing1    Lecturer             @relation("Pembimbing1YudisiumRegistrations", fields: [dosenPembimbing1Id], references: [id]) // Dosen Pembimbing 1
  dosenPembimbing1Id  Int
  dosenPembimbing2    Lecturer             @relation("Pembimbing2YudisiumRegistrations", fields: [dosenPembimbing2Id], references: [id]) // Dosen Pembimbing 2
  dosenPembimbing2Id  Int
  sidangScheme        SidangScheme         @relation(fields: [sidangSchemeId], references: [id])
  sidangSchemeId      Int
  cumlaudeScheme      CumlaudeScheme       @relation(fields: [cumlaudeSchemeId], references: [id])
  cumlaudeSchemeId    Int
  cumlaudeSubmissions CumlaudeSubmission[]
}

model CumlaudeSubmission {
  id                     Int                  @id @default(autoincrement())
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime
  data                   Json
  yudisiumRegistration   YudisiumRegistration @relation(fields: [yudisiumRegistrationId], references: [id])
  yudisiumRegistrationId Int
}

model TemplateFile {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime
  fileName  String
  fileUrl   String
}
